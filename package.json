{
  "name": "simprint",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "slotkit generate-imports && slotkit dev",
    "build:development": "vite build --mode development",
    "build:production": "vite build --mode production",
    "build:test": "vite build --mode test",
    "deploy:prepare-version": "node deploy/prepare-version.mjs",
    "deploy:build": "node deploy/build.mjs",
    "deploy:latest-json": "node deploy/generate-latest-json.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,md}\"",
    "preview": "vite preview",
    "generate-imports": "slotkit generate-imports",
    "rust:fmt": "cd src-tauri && cargo fmt",
    "rust:fmt:check": "cd src-tauri && cargo fmt -- --check",
    "rust:clippy": "cd src-tauri && cargo clippy",
    "rust:clippy:fix": "cd src-tauri && cargo clippy --fix",
    "rust:check": "cd src-tauri && cargo check"
